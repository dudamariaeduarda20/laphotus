# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sports_photos"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="xxxxx"
SUPABASE_SERVICE_KEY="xxxxx"

# AWS
AWS_REGION="eu-west-1"
AWS_ACCESS_KEY_ID="xxxxx"
AWS_SECRET_ACCESS_KEY="xxxxx"
# Opcional: fotos vivem no Supabase Storage por default. AWS_S3_BUCKET só é
# lido se o Supabase Storage estiver desativado (fallback S3 legado).
AWS_S3_BUCKET="sports-photos-prod"
AWS_REKOGNITION_COLLECTION_ID="laphotus-faces-prod"
# Facial search: AWS Rekognition ativa sempre que creds presentes (a menos que
# esta flag seja "false"). Threshold configurável via AWS_FACE_THRESHOLD (default 65).
# Se Rekognition indisponível: fallback pgvector (80% tolerance).
AWS_REKOGNITION_ENABLED="true"
AWS_FACE_THRESHOLD="65"

# Stripe
NEXT_PUBLIC_STRIPE_PUBLIC_KEY="pk_live_xxxxx"
STRIPE_SECRET_KEY="sk_live_xxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxx"

# Cloudflare
NEXT_PUBLIC_CLOUDFLARE_CDN="https://cdn.example.com"

# Redis
REDIS_URL="redis://localhost:6379"

# Email
RESEND_API_KEY="re_xxxxx"

# Auth (REQUIRED in production — generate with: openssl rand -hex 32)
AUTH_SECRET="change-me-use-openssl-rand-hex-32"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
